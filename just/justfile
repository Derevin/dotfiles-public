# Global justfile — recipes available everywhere via `just -g`

sync:
    sync.sh

[no-cd]
task-list:
    task-list.sh --status todo active

[private]
_claude-model:
    #!/usr/bin/env bash
    printf '%s\n' haiku sonnet opus

# Fresh claude at a chosen model
[no-cd]
claude model='haiku':
    #!/usr/bin/env bash
    exec claude --model "{{model}}"

dotfiles:
    @# background_takeover
    workspace-dotfiles.sh

# Per-repo workspaces: wire a repo path to a layout script. `@#` body markers
# (silent no-ops) drive the M-j chooser without using the doc-comment slot:
# `@# background_takeover` sets dispatch mode, `@# requires-repo <name>` hides
# the recipe unless ~/repos/<name> exists. Add your own, e.g.:
# myrepo:
#     @# background_takeover
#     @# requires-repo myrepo
#     workspace-solo.sh ~/repos/myrepo      # claude left, two terminals right
# myrepo-dual:
#     @# background_takeover
#     workspace-dual.sh ~/repos/myrepo      # claude ×2 + two terminals below
